# config/wordlists.env.example
#
# Caminhos padrão de wordlists usados pelos scripts de descoberta de conteúdo
# (discovery.sh e a etapa de gobuster/ffuf do web-check.sh). Copie para um
# arquivo local (ex.: .env) se quiser apontar para wordlists diferentes —
# NÃO commite esse arquivo com caminhos específicos de um cliente.
#
# IMPORTANTE: este toolkit não usa e não deve usar wordlists de senha/login
# (ex.: rockyou.txt) — apenas descoberta de caminhos/arquivos. Não aponte
# estas variáveis para wordlists de credenciais.

# --- Wordlists de descoberta de conteúdo por perfil ---
WORDLIST_SAFE=/usr/share/seclists/Discovery/Web-Content/common.txt
WORDLIST_NORMAL=/usr/share/seclists/Discovery/Web-Content/directory-list-2.3-small.txt
WORDLIST_DEEP=/usr/share/seclists/Discovery/Web-Content/directory-list-2.3-medium.txt

# --- Extensões controladas verificadas em todos os perfis ---
# (gobuster usa formato "txt,html,..."; o ffuf é derivado automaticamente)
DISCOVERY_EXTENSIONS=txt,html,conf,bak,old,json,xml

# --- Templates do Nuclei (opcional — o Nuclei também atualiza os próprios) ---
NUCLEI_TEMPLATES_DIR=$HOME/nuclei-templates

# --- SecLists (usado como base para os caminhos acima) ---
SECLISTS_DIR=/usr/share/seclists
