# config/profiles.env.example
#
# Exemplo de variáveis de ambiente para ajustar limites por perfil
# (safe / normal / deep). Copie para um arquivo local (ex.: .env) se quiser
# sobrescrever os padrões — NÃO commite esse arquivo com valores reais de
# cliente. O .gitignore já bloqueia `.env` e `.env.*`.
#
# Para usar:
#   cp config/profiles.env.example .env
#   set -a; source .env; set +a
#   ./scripts/web-check.sh http://127.0.0.1:8080 normal
#
# Todas as variáveis têm um valor padrão seguro no código (scripts/lib/common.sh)
# — só defina aqui o que você realmente quer mudar.

# --- Gobuster (threads simultâneas) ---
GOBUSTER_THREADS_SAFE=10
GOBUSTER_THREADS_NORMAL=20
GOBUSTER_THREADS_DEEP=30

# --- FFUF (requisições por segundo) ---
FFUF_RATE_SAFE=20
FFUF_RATE_NORMAL=50
FFUF_RATE_DEEP=80

# --- Nuclei (rate-limit em requisições por segundo) ---
NUCLEI_RATE_LIMIT_SAFE=10
NUCLEI_RATE_LIMIT_NORMAL=10
NUCLEI_RATE_LIMIT_DEEP=5

# --- Nuclei (tags por perfil) ---
NUCLEI_TAGS_SAFE=exposure,misconfig
NUCLEI_TAGS_NORMAL=exposure,misconfig,cve
# Perfil deep não define tags por padrão (cobertura ampla); defina aqui se
# quiser restringir, ex.: NUCLEI_TAGS_DEEP=exposure,misconfig,cve,default-login
NUCLEI_TAGS_DEEP=

# --- Nmap (quantidade de portas comuns analisadas no perfil de exposição) ---
NMAP_TOP_PORTS_SAFE=100
NMAP_TOP_PORTS_NORMAL=1000
# Perfil deep sempre varre 1-65535 (não configurável, por desenho).
